{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/proxy?path=/api/:path*"
    },
    {
      "source": "/session/:path*",
      "destination": "/api/proxy?path=/session/:path*"
    },
    {
      "source": "/it-admin/:path*",
      "destination": "/api/proxy?path=/it-admin/:path*"
    },
    {
      "source": "/it-auth/:path*",
      "destination": "/api/proxy?path=/it-auth/:path*"
    },
    {
      "source": "/webdata/:path*",
      "destination": "/api/proxy?path=/webdata/:path*"
    },
    {
      "source": "/health",
      "destination": "/api/proxy?path=/health"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/proxy?path=/sitemap.xml"
    },
    {
      "source": "/",
      "destination": "/api/render"
    },
    {
      "source": "/pricing",
      "destination": "/api/render"
    },
    {
      "source": "/blog",
      "destination": "/api/render"
    },
    {
      "source": "/blog/:slug",
      "destination": "/api/render?blogSlug=:slug"
    },
    {
      "source": "/comparison/google-classroom-notion",
      "destination": "/api/render?comparison=google-classroom-notion"
    },
    {
      "source": "/institutes/:slug",
      "destination": "/api/render?instituteSlug=:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}