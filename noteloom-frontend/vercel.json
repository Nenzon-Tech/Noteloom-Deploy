{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/proxy?path=/api/:path*"
    },
    {
      "source": "/session/:path*",
      "destination": "/api/proxy?path=/session/:path*"
    },
    {
      "source": "/webdata/:path*",
      "destination": "/api/proxy?path=/webdata/:path*"
    },
    {
      "source": "/health",
      "destination": "/api/proxy?path=/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}