# ============================================
# NoteLoom Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.

# --- MongoDB ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# --- JWT (REQUIRED — generate a strong random string, e.g. openssl rand -base64 64) ---
JWT_SECRET=your_very_long_random_secret_here

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Email (Nodemailer / Gmail) ---
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# --- Google Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Cloudinary (for file/image/video uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Cloudflare AI (Fallback AI provider) ---
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
